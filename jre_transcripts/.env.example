# Copy to .env and fill in. The CLI auto-loads .env from the project root.

# --- Kaggle ---
# Get an API token from https://www.kaggle.com/settings -> "Create New Token".
# Either set these two vars, or place kaggle.json at ~/.kaggle/kaggle.json.
KAGGLE_USERNAME=
KAGGLE_KEY=
# The Kaggle dataset slug to pull JRE transcripts from, in "owner/dataset-name"
# form. Find candidates with:  python -m jre_pipeline search "joe rogan transcript"
JRE_KAGGLE_DATASET=

# --- LLM provider ---
# anthropic (default) or openai
LLM_PROVIDER=anthropic
LLM_MODEL=
# Anthropic (default model: claude-opus-4-7)
ANTHROPIC_API_KEY=
# OpenAI (default model: gpt-4o)
OPENAI_API_KEY=

# --- Paths (optional overrides) ---
# JRE_DATA_DIR=jre_transcripts/data
# JRE_DB_PATH=jre_transcripts/data/jre.db
# JRE_VAULT_DIR=jre_transcripts/obsidian
